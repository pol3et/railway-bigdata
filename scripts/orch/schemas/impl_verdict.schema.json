{
  "type": "object",
  "additionalProperties": false,
  "required": ["gap_id", "branch", "mergeable", "tests", "dod_met", "blocked"],
  "properties": {
    "gap_id": { "type": "string" },
    "branch": { "type": "string" },
    "pr_url": { "type": ["string", "null"] },
    "pr_number": { "type": ["integer", "null"] },
    "mergeable": { "type": "boolean" },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "integration", "live", "full_suite"],
      "properties": {
        "unit": { "type": "string", "enum": ["pass", "fail", "skipped"] },
        "integration": { "type": "string", "enum": ["pass", "fail", "skipped"] },
        "live": { "type": "string", "enum": ["pass", "fail", "skipped", "not_needed"] },
        "full_suite": { "type": "string", "description": "e.g. '88 passed'" }
      }
    },
    "dod_met": { "type": "array", "items": { "type": "string" }, "description": "Definition-of-Done items satisfied" },
    "dod_unmet": { "type": "array", "items": { "type": "string" } },
    "files_changed": { "type": "array", "items": { "type": "string" } },
    "blocked": { "type": "boolean" },
    "blocker": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}

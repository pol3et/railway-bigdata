{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "findings"],
  "properties": {
    "verdict": { "type": "string", "enum": ["approve", "request_changes"] },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "title", "location", "why", "fix"],
        "properties": {
          "priority": { "type": "string", "enum": ["P1", "P2", "P3", "P4"] },
          "title": { "type": "string" },
          "location": { "type": "string", "description": "file:line" },
          "why": { "type": "string" },
          "fix": { "type": "string" }
        }
      }
    },
    "contract_items_verified": { "type": "array", "items": { "type": "string" } }
  }
}

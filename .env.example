# Copy to .env (gitignored) and adjust if needed.
# Defaults match bronze/config.py and silver/config.py so code runs unchanged
# against the Docker MinIO stack.

# S3 / MinIO endpoint as seen from code running on the host
S3_ENDPOINT=http://localhost:9000
S3_KEY=admin
S3_SECRET=password123

# Lakehouse buckets
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold

# MinIO web console: http://localhost:9001
# Login = S3_KEY / S3_SECRET

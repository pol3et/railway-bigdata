# Copy to .env (gitignored) and adjust if needed.
# Defaults match bronze/config.py and silver/config.py so code runs unchanged
# against the Docker MinIO stack.

# S3 / MinIO endpoint as seen from code running on the host
S3_ENDPOINT=http://localhost:9000
S3_KEY=admin
S3_SECRET=password123

# Lakehouse buckets
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold

# MinIO web console: http://localhost:9001
# Login = S3_KEY / S3_SECRET

# Spark / Big Data engine (GAP-017)
# Set JAVA_HOME to a JDK 17 or 21 install before running Spark 4.1.
# JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-21
# Optional on native Windows: HADOOP_HOME with winutils/hadoop.dll for Hadoop 3.4.x.
# Spark s3a:// MinIO connector packages for spark.jars.packages (GAP-009).
SPARK_S3A_PACKAGES=org.apache.hadoop:hadoop-aws:3.4.1,software.amazon.awssdk:bundle:2.24.6
